# ============ Azure Storage (database) ============
# When this is set, the app persists recipes/votes/comments to Azure Table
# Storage. Leave it unset to run with the built-in in-memory sample data
# (great for local development and previews).
#
# Get it from: Azure Portal > Storage account > Access keys > Connection string
AZURE_STORAGE_CONNECTION_STRING=

# For local development you can run the Azurite emulator and use:
# AZURE_STORAGE_CONNECTION_STRING=UseDevelopmentStorage=true

# Optional: override the table name prefix (defaults to "careerrecipe").
AZURE_TABLE_PREFIX=careerrecipe

# ============ Auth ============
# Secret used to sign session cookies. Set a long random value in production
# (e.g. `openssl rand -hex 32`). A weak dev fallback is used if left unset.
AUTH_SECRET=
